    "postcss-merge-queries": "^1.0.3",
    "posthtml": "^0.16.6",
    "posthtml-beautify": "^0.7.0",
    "remark-breaks": "^4.0.0",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "astro-auto-import": "^0.4.4",
